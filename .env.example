# ── Pi OBD2 Telemetry — Environment Configuration ──
# Copy this file to .env and update the values below.

# Application
APP_NAME=pi-obd2-api
APP_ENV=prod
API_HOST=0.0.0.0
API_PORT=8000

# OBD-II Bluetooth Connection
# Replace with the serial device bound via `sudo rfcomm bind 0 <MAC_ADDRESS>`
OBD_PORT=/dev/rfcomm0
OBD_BAUDRATE=38400
OBD_TIMEOUT_SECONDS=2.0
POLL_INTERVAL_SECONDS=1.0
RECONNECT_BASE_DELAY_SECONDS=1.0
RECONNECT_MAX_DELAY_SECONDS=30.0

# Data storage (absolute path on the Raspberry Pi)
DATA_DIR=/home/pi/pi-obd2/data
